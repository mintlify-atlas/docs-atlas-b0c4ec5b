  "keyFeatures": [
    "End-to-end encrypted email with Skiff Mail",
    "End-to-end encrypted calendar with event management",
    "End-to-end encrypted document editor (Pages)",
    "End-to-end encrypted file storage (Drive)",
    "Private client-side search indexing",
    "Asymmetric encryption with TweetNaCl",
    "Symmetric encryption with ChaCha20Poly1305",
    "Reusable UI component library (Nightwatch UI)",
    "Rich text editor built on ProseMirror",
    "GraphQL API integration",
    "Custom domains and email aliases",
    "Anonymous crypto wallet payments"
  ],
  "publicApiSurface": [
    "generatePublicPrivateKeyPair() - Generate asymmetric key pairs",
    "stringEncryptAsymmetric() - Asymmetric string encryption",
    "stringDecryptAsymmetric() - Asymmetric string decryption",
    "generateSymmetricKey() - Generate symmetric encryption keys",
    "encryptSymmetric() - Symmetric data encryption",
    "decryptSymmetric() - Symmetric data decryption",
    "generateHash() - SHA-512 hashing",
    "signDetached() - Digital signature generation",
    "verifyDetached() - Digital signature verification",
    "createJSONWrapperDatagram() - Create versioned data containers",
    "Button - Reusable button component",
    "InputField - Text input component",
    "Dialog - Modal dialog component",
    "Dropdown - Dropdown menu component",
    "Avatar - User avatar component",
    "IconText - Icon with text component"
  ]
